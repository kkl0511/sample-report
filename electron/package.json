{
  "name": "biomotion-pitching-report",
  "version": "1.0.0",
  "description": "바이오모션 투수 리포트 — Electron 데스크탑 앱",
  "author": "BBL Lab (kklee@kookmin.ac.kr)",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.biomotion.pitching-report",
    "productName": "바이오모션 투수 리포트",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "바이오모션_투수리포트_offline.html",
      "icon.png"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.education",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "icon.png",
      "identity": null
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Education",
      "icon": "icon.png"
    },
    "dmg": {
      "title": "바이오모션 투수 리포트 ${version}"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
